{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel API Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "--", "vercel", "dev", "--yes"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Vite Frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite"],
      "port": 3000
    },
    {
      "name": "Local Backend Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["local-server.js"],
      "port": 3001
    }
  ]
}
