{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel API Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev"],
      "port": 3000
    },
    {
      "name": "Vite Frontend",
      "runtimeExecutable": "npx",
