{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "bash scripts/vercel-ignore-build-step.sh",
  "functions": {
    "api/cron/send-scheduled-newsletters.ts": {
      "maxDuration": 300
    },
    "api/admin/retrograde-rename.ts": {
      "maxDuration": 300
    },
    "api/gallery/[...path].ts": {
      "maxDuration": 300
    },
    "api/cron/sync-photos.ts": {
      "maxDuration": 300
    },
    "api/cron/sync-gallery.ts": {
      "maxDuration": 250
    },
    "api/admin/sync-library.ts": {
      "maxDuration": 300
    },
    "api/admin/drive-download.ts": {
      "maxDuration": 300
    },
    "api/**/*.ts": {
      "maxDuration": 60
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-payouts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-photos",
      "schedule": "0 3,15 * * *"
    },
    {
      "path": "/api/cron/sync-gallery",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/retry-pricing-refund",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/send-scheduled-newsletters",
      "schedule": "0 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/AI_WRITING_PROMPT_FOR_CONTRIBUTORS.md",
      "destination": "/bookclub/prompt",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|_next|static|sql|\\.well-known|@vite|@react-refresh|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/nostr.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" },
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/image-sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|woff|woff2|ttf|otf|eot|svg|webp|avif|jpg|jpeg|png|gif|ico|mp4|webm))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' blob: 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://analytics.ahrefs.com https://va.vercel-scripts.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' blob: https: wss:; media-src 'self' data:; frame-src 'self' https://challenges.cloudflare.com; worker-src 'self' blob:;"
        }
      ]
    },
    {
      "source": "/tiktok-downloader/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
